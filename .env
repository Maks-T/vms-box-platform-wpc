COMPOSE_PROJECT_NAME=vms-box-wpc

# Application Config
APP_NAME="VMS-NC Box (WPC)"
APP_ENV=local
APP_KEY=base64:17+jjutZVNB1G4XuEjkPcc50QquHN0B97bkDVKvliqk=
APP_DEBUG=true
APP_URL=http://localhost
APP_LOCALE=ru
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ru_RU

# Docker Infrastructure Ports (External)
# Менять при установке на сервер, если порт 80 уже занят
APP_PORT=80
VITE_PORT=5173
ADMINER_PORT=8080
MEILISEARCH_PORT=7700

# Database (PostgreSQL 18.3)
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=vms_wpc_db
DB_USERNAME=vms_user
DB_PASSWORD=vms_secret_pass

# Redis & Drivers ---
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
FILESYSTEM_DISK=local

SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false

# Queue System
QUEUE_CONNECTION=redis
REDIS_QUEUE_RETRY_AFTER=90
REDIS_FAST_RETRY_AFTER=600
REDIS_LONG_RETRY_AFTER=3600

# Search Engine
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=masterKey

# Logging
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# Mail
MAIL_MAILER=log
MAIL_FROM_ADDRESS="system@vms-box.local"
MAIL_FROM_NAME="${APP_NAME}"

# Vite
VITE_APP_NAME="${APP_NAME}"

# Industry Context
VMS_INDUSTRY=wpc
